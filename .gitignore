# Environment variables and secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Raw, private and generated data
data/raw/*
data/external/*
data/interim/*
data/processed/*

# Keep directory structure
!data/raw/.gitkeep
!data/external/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Database and temporary files
*.db
*.sqlite
*.sqlite3
*.duckdb
*.log
tmp/
logs/

# Credentials and API keys
credentials/
secrets/
*.pem
*.key

# IDE and operating system
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated reports
reports/figures/*
reports/tables/*
!reports/figures/.gitkeep
!reports/tables/.gitkeep
